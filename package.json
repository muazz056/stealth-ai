{
  "name": "interview-stealth-assist",
  "version": "1.0.0",
  "description": "AI-powered interview assistant with real-time transcription and stealth overlay",
  "author": "Chaudhry Muaz",
  "private": true,
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron main.cjs",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron main.cjs\"",
    "backend": "node backend/server.cjs",
    "backend-dev": "nodemon backend/server.cjs",
    "start": "concurrently \"npm run backend\" \"npm run dev\" \"wait-on http://localhost:3001 http://localhost:5173 && electron main.cjs\"",
    "create-admin": "node backend/create-admin.cjs",
    "install-stealth": "npm install ffi-napi ref-napi",
    "postinstall": "echo 'For Windows stealth features, run: npm run install-stealth'",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@google/genai": "^1.34.0",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "electron-screenshot": "^1.0.5",
    "express": "^4.18.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "mammoth": "^1.11.0",
    "mic": "^2.1.2",
    "mongodb": "^6.12.0",
    "multer": "^2.0.2",
    "node-record-lpcm16": "^1.0.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.34.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-supersub": "^1.0.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "ffi-napi": "^4.0.3",
    "ref-napi": "^3.0.3"
  },
  "devDependencies": {
    "@types/electron": "^1.4.38",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.interviewassist.stealthai",
    "productName": "Stealth Assist",
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "auth.cjs",
      "browser-preload.js",
      "backend/**/*",
      "speech_bridge.py",
      "deepgram_speech_bridge.py",
      "deepgram_bridge.cjs",
      "node_modules/**/*",
      "!node_modules/ffi-napi/**/*",
      "!node_modules/ref-napi/**/*",
      "package.json",
      ".env"
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stealth Assist"
    },
    "portable": {
      "artifactName": "InterviewStealthAssist-Portable.exe"
    }
  }
}
